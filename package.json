{
  "name": "easymailing-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "Easymailing SDK monorepo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/easymailing/easymailing-sdk.git"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10.10"
  },
  "packageManager": "pnpm@10.34.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' run build",
    "test": "pnpm -r --filter './packages/**' run test",
    "lint": "pnpm -r --filter './packages/**' run lint",
    "generate": "node scripts/generate.mjs",
    "check": "pnpm -r --filter './packages/**' run check"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.5.0"
  }
}
