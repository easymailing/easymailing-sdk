{
  "openapi": "3.1.0",
  "info": { "title": "Test", "version": "1.0" },
  "paths": {
    "/stores": {
      "get": { "operationId": "list_stores", "responses": { "200": { "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Store-store.read" } } } } } } }
    },
    "/stores/{storeResourceId}/products": {
      "get": {
        "operationId": "list_products",
        "parameters": [{ "name": "storeResourceId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Product-product.read" } } } } } }
      }
    },
    "/stores/{storeResourceId}/products/{productResourceId}/variants": {
      "get": {
        "operationId": "list_variants",
        "parameters": [
          { "name": "storeResourceId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "productResourceId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Variant-variant.read" } } } } } }
      }
    }
  },
  "components": { "schemas": {} }
}
